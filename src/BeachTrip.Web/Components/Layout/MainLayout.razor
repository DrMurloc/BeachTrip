@using BeachTrip.Infrastructure
@using BeachTrip.Infrastructure.Projections
@using BeachTrip.Web.Live
@using BeachTrip.Web.Services
@using Microsoft.AspNetCore.Components.Routing
@inherits LayoutComponentBase
@implements IDisposable
@inject IdentityService Identity
@inject IViewStore ViewStore
@inject LiveUpdates Live
@inject NavigationManager Nav

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">BeachTrip</MudText>
        <MudSpacer />

        @if (_identity is not null)
        {
            <MudMenu Label="@_identity.DisplayName"
                     EndIcon="@Icons.Material.Filled.ArrowDropDown"
                     Variant="Variant.Outlined"
                     Color="Color.Inherit"
                     Class="mr-2">
                <div class="pa-2" style="min-width: 260px;">
                    <MudTextField @bind-Value="_filter"
                                  Placeholder="Search users..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  DebounceInterval="0" />
                </div>
                <MudDivider />
                <div style="max-height: 320px; overflow-y: auto;">
                    @foreach (var a in FilteredAttendees())
                    {
                        <MudMenuItem @key="a.Id" OnClick="@(() => SwitchTo(a))">
                            @a.DisplayName
                            @if (a.Id == _identity.AttendeeId.ToString())
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="ml-2" />
                            }
                        </MudMenuItem>
                    }
                </div>
                <MudDivider />
                <MudMenuItem OnClick="RegisterAnother" Icon="@Icons.Material.Filled.SwitchAccount">
                    Switch User
                </MudMenuItem>
            </MudMenu>
        }
        else if (!IsOnSignInPage)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       OnClick="@(() => Nav.NavigateTo("/"))"
                       StartIcon="@Icons.Material.Filled.Login">
                Sign in
            </MudButton>
        }
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private UserIdentity? _identity;
    private IReadOnlyList<AttendeeView> _attendees = Array.Empty<AttendeeView>();
    private string _filter = "";

    private bool IsOnSignInPage =>
        string.IsNullOrEmpty(Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/'));

    // Dedupes by display name (case-insensitive) so any leftover bogus aggregates
    // collapse to one row. Prefers the seeded KnownIds GUID for the family names
    // so "DrMurloc" always switches to the canonical aggregate that owns 2F Right.
    private IEnumerable<AttendeeView> FilteredAttendees() =>
        _attendees
            .Where(a => string.IsNullOrWhiteSpace(_filter) ||
                        a.DisplayName.Contains(_filter, StringComparison.OrdinalIgnoreCase))
            .GroupBy(a => a.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Select(PreferCanonical)
            .OrderBy(a => a.DisplayName);

    private static AttendeeView PreferCanonical(IGrouping<string, AttendeeView> group)
    {
        var seededId = TrySeededId(group.Key);
        if (seededId is not null)
        {
            var canonical = group.FirstOrDefault(a => Guid.Parse(a.Id) == seededId.Value);
            if (canonical is not null) return canonical;
        }
        return group.OrderBy(a => a.Id, StringComparer.Ordinal).First();
    }

    private static Guid? TrySeededId(string handle) => handle.ToLowerInvariant() switch
    {
        "drmurloc" => KnownIds.DrMurloc,
        "iraiah"   => KnownIds.Iraiah,
        "murky"    => KnownIds.Murky,
        _ => null,
    };

    protected override async Task OnInitializedAsync()
    {
        _identity = await Identity.GetCurrent();
        _attendees = await ViewStore.ListAttendees();
        Live.ViewChanged += OnViewChanged;
        // Re-check identity on every navigation — the layout instance persists across
        // route changes, so without this it'd keep stale state after a sign-in/out.
        Nav.LocationChanged += OnLocationChanged;
    }

    public void Dispose()
    {
        Live.ViewChanged -= OnViewChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await InvokeAsync(async () =>
        {
            _identity = await Identity.GetCurrent();
            _attendees = await ViewStore.ListAttendees();
            StateHasChanged();
        });
    }

    private async void OnViewChanged(ViewUpdated msg)
    {
        if (msg.AggregateType != "Attendee") return;
        await InvokeAsync(async () =>
        {
            _attendees = await ViewStore.ListAttendees();
            StateHasChanged();
        });
    }

    private async Task SwitchTo(AttendeeView attendee)
    {
        if (_identity is not null && attendee.Id == _identity.AttendeeId.ToString()) return;
        await Identity.SignIn(attendee.DisplayName, Guid.Parse(attendee.Id));
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private async Task RegisterAnother()
    {
        // Also functions as "sign out" — drops identity and sends you back to home
        // where you can re-sign-in as someone else, register fresh, or browse anonymously.
        await Identity.SignOut();
        Nav.NavigateTo("/");
    }
}
